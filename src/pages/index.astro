---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const baseeraEditions = await getCollection('baseera');
const latestEditions = baseeraEditions
  .sort((a, b) => b.data.edition - a.data.edition)
  .slice(0, 4);
---

<BaseLayout title="Muhammad Seedat — The South African Bedouin" description="Decoding the world, life & human systems — through a South African Bedouin lens. Industrial Engineer. Systems Architect. Ex-Accenture. Qatar-based.">

<!-- ─── HERO ─────────────────────────────────────────── -->
<div class="hero">
  <div class="wrap">
    <div class="hero-eyebrow">@southafricanbedouin</div>
    <h1 class="hero-name">Muhammad Seedat.</h1>
    <p class="hero-identity">The South African Bedouin</p>
    <p class="hero-tagline">
      Decoding the world, life &amp; human systems —<br />
      through a South African Bedouin lens.
    </p>
    <div class="hero-creds">
      <span>Industrial Engineer</span><span class="sep">·</span>
      <span>Systems Architect</span><span class="sep">·</span>
      <span>Ex-Accenture</span><span class="sep">·</span>
      <span>Qatar-based</span><span class="sep">·</span>
      <span>Father</span><span class="sep">·</span>
      <span>Barista</span><span class="sep">·</span>
      <span>Belief in one Creator</span>
    </div>
    <div class="hero-actions">
      <a href="#newsletter" class="btn-dark">Read the newsletter →</a>
      <a href="#resources" class="btn-text">Explore resources</a>
    </div>
  </div>
</div>

<!-- ─── ABOUT STRIP ──────────────────────────────────── -->
<div class="about-strip" id="about">
  <div class="wrap-wide">
    <div class="about-strip-inner">

      <div class="about-strip-left">
        <div class="about-strip-name mono">Muhammad Seedat</div>
        <div class="about-strip-handle mono">@southafricanbedouin</div>
        <div class="about-strip-img">
          <img src="/ms_profilepic_casual.png" alt="Muhammad Seedat" />
        </div>
        <div class="about-socials">
          <a href="https://linkedin.com/in/southafricanbedouin" target="_blank" rel="noopener">LinkedIn ↗</a>
          <a href="https://x.com/southafricanbedouin" target="_blank" rel="noopener">X ↗</a>
          <a href="https://instagram.com/southafricanbedouin" target="_blank" rel="noopener">Instagram ↗</a>
        </div>
      </div>

      <div class="about-strip-body">
        <p>
          South African-born. Qatar-based. Half my life in each.
          Industrial Engineer by training. Systems Architect by practice.
          I spent years learning how large, complex organisations actually work —
          and more importantly, why they don't.
        </p>
        <p>
          The handle is <strong>@southafricanbedouin</strong>. The Bedouin navigated without road signs —
          by stars, memory, and an understanding of the landscape that only comes from crossing it.
          That's the operating model here.
        </p>
        <p>
          Father. Barista. Someone who believes in one Creator and finds that belief everywhere —
          in systems, in people, in the way things connect when you slow down enough to see it.
        </p>
        <details class="about-long">
          <summary class="about-long-toggle mono">Read more ↓</summary>
          <div class="about-long-body">
            <p>
              I've spent over 18 years building systems nobody had built before. Considering the Context.
              Greenfield hospitals and manufacturing facilities. Digital Transformations.
              National education roadmaps. Schools for children the world forgot.
              Supply chains that moved across 70 nationalities.
              And now — the AI transition that's reshaping all of it.
            </p>
            <p>
              I'm not a specialist. I'm an architect. I connect the dots that specialists miss —
              across Healthcare, Education, Government, and the systems that sit beneath them all.
            </p>
            <p class="about-pillars">
              What I write about: AI and what it actually means for leaders in Healthcare and Education ·
              Systems thinking as an unfair advantage in the AI moment ·
              Ancient frameworks that still outperform the latest productivity trend ·
              The Middle East, Africa, and the Global South — the perspective most platforms ignore.
            </p>
            <p>
              Every week in <em>The Sand &amp; Silicon Byte</em>, I decode one development at the intersection
              of AI, human systems, and culture. Just the insights.
            </p>
          </div>
        </details>
        <blockquote class="about-quote">
          "The systems you build today determine who leads tomorrow."
        </blockquote>
      </div>

    </div>
  </div>
</div>

<!-- ─── RESOURCES ─────────────────────────────────────── -->
<div class="section" id="resources">
  <div class="wrap-wide">

    <div class="section-label">Resources</div>

    <div class="resources-tabs">
      <button class="res-tab active" data-tab="tools">🛠 Tools</button>
      <button class="res-tab" data-tab="guides">📖 Guides</button>
      <button class="res-tab" data-tab="prompts">✦ Prompts</button>
      <button class="res-tab" data-tab="models">⬡ Models</button>
    </div>

    <!-- TOOLS -->
    <div class="res-panel active" id="tab-tools">
      <div class="res-grid">

        <div class="res-card">
          <span class="res-card-badge free">Free · No signup</span>
          <div class="res-card-title">Qatar Newcomer Navigator</div>
          <div class="res-card-desc">The complete guide to arriving in Qatar. QID, driving licence, bank account, school enrollment — step by step, in plain language.</div>
          <div class="res-card-region">🇶🇦 Qatar · Expat Life</div>
          <div class="res-card-link mono">Open tool →</div>
        </div>

        <div class="res-card">
          <span class="res-card-badge free">Free · Email for full access</span>
          <div class="res-card-title">Qatar School Finder</div>
          <div class="res-card-desc">Filter by curriculum, area, fees, and special needs provisions. Honest waiting-list reality included.</div>
          <div class="res-card-region">🇶🇦 Qatar · Education</div>
          <div class="res-card-link mono">Find a school →</div>
        </div>

        <div class="res-card">
          <span class="res-card-badge free">Free · 5 minutes</span>
          <div class="res-card-title">GCC AI Readiness Assessment</div>
          <div class="res-card-desc">10 questions. A clear score. Next steps designed for Gulf professionals — not Silicon Valley startups.</div>
          <div class="res-card-region">🌙 Gulf &amp; Middle East · AI</div>
          <div class="res-card-link mono">Take the assessment →</div>
        </div>

        <div class="res-card">
          <span class="res-card-badge free">Free · Email for full guide</span>
          <div class="res-card-title">South African to Gulf — Relocation Guide</div>
          <div class="res-card-desc">SARS tax, credential recognition, driving licence conversion, SA banking abroad. Nobody else makes this guide.</div>
          <div class="res-card-region">🇿🇦 South Africa → 🌙 Gulf</div>
          <div class="res-card-link mono">Get the guide →</div>
        </div>

      </div>
      <div style="margin-top:16px;">
        <p class="res-note mono">More tools launching monthly — <a href="#newsletter">subscribe to be notified</a>.</p>
      </div>
    </div>

    <!-- GUIDES -->
    <div class="res-panel" id="tab-guides">
      <ul class="res-list">
        <li class="res-list-item">
          <div class="res-list-num mono">01</div>
          <div class="res-list-body">
            <div class="res-list-title">Parent's AI Starter Guide</div>
            <div class="res-list-desc">What every parent needs to know about AI before their children know more than them. Plain language. Practical steps.</div>
            <div class="res-list-meta mono"><span>Family · AI</span><span>Free · Email</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
        <li class="res-list-item">
          <div class="res-list-num mono">02</div>
          <div class="res-list-body">
            <div class="res-list-title">Teacher's AI Guide — Gulf &amp; Africa Edition</div>
            <div class="res-list-desc">Built for teachers in international and African school systems. Not translated from a Silicon Valley use case.</div>
            <div class="res-list-meta mono"><span>Education · AI</span><span>Free · Email</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
        <li class="res-list-item">
          <div class="res-list-num mono">03</div>
          <div class="res-list-body">
            <div class="res-list-title">Gulf Family Relocation Comparison</div>
            <div class="res-list-desc">Qatar vs UAE vs Saudi vs Bahrain — schooling, housing, costs, lifestyle. Honest, experienced, no tourism copy.</div>
            <div class="res-list-meta mono"><span>Gulf · Expat Life</span><span>Free</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
        <li class="res-list-item">
          <div class="res-list-num mono">04</div>
          <div class="res-list-body">
            <div class="res-list-title">Board AI Briefing Template</div>
            <div class="res-list-desc">One-page framework for executives presenting AI risk and opportunity to their board. Plain language. Non-technical.</div>
            <div class="res-list-meta mono"><span>Leadership · AI</span><span>Free · Email</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
      </ul>
      <div class="res-coming">
        More guides <strong>launching soon</strong>. <a href="#newsletter">Subscribe</a> to be first.
      </div>
    </div>

    <!-- PROMPTS -->
    <div class="res-panel" id="tab-prompts">
      <ul class="res-list">
        <li class="res-list-item">
          <div class="res-list-num mono">01</div>
          <div class="res-list-body">
            <div class="res-list-title">Teacher Prompt Pack — 50 Ready-to-Use Prompts</div>
            <div class="res-list-desc">Lesson planning, differentiation, assessment rubrics, parent communication. First 10 free, full 50 after email.</div>
            <div class="res-list-meta mono"><span>Education</span><span>Free → Email</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
        <li class="res-list-item">
          <div class="res-list-num mono">02</div>
          <div class="res-list-body">
            <div class="res-list-title">Executive AI Prompt Pack — 30 Leadership Prompts</div>
            <div class="res-list-desc">Strategic planning, communications, decision frameworks, board preparation. Built for Gulf and African leadership contexts.</div>
            <div class="res-list-meta mono"><span>Leadership</span><span>$9</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
        <li class="res-list-item">
          <div class="res-list-num mono">03</div>
          <div class="res-list-body">
            <div class="res-list-title">Parent AI Prompts — Conversations with your Children</div>
            <div class="res-list-desc">Ready-made prompts for talking to your kids about AI, screen time, creativity, and what to expect at school.</div>
            <div class="res-list-meta mono"><span>Parenting · Family</span><span>Free</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
      </ul>
      <div class="res-coming">Full prompt library <strong>coming soon</strong>.</div>
    </div>

    <!-- MODELS / FRAMEWORKS -->
    <div class="res-panel" id="tab-models">
      <ul class="res-list">
        <li class="res-list-item">
          <div class="res-list-num mono">01</div>
          <div class="res-list-body">
            <div class="res-list-title">The M.E.S.H. Protocol</div>
            <div class="res-list-desc">Mental Models · Ethics · Systems Thinking · Humanity. A framework for navigating the AI transition without losing what makes us human.</div>
            <div class="res-list-meta mono"><span>Framework · AI</span><span>In development</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
        <li class="res-list-item">
          <div class="res-list-num mono">02</div>
          <div class="res-list-body">
            <div class="res-list-title">AI Strategy Canvas</div>
            <div class="res-list-desc">A one-page strategic framework for organisations entering the AI transition. Six boxes. Clear thinking. Free to download.</div>
            <div class="res-list-meta mono"><span>Strategy · Leadership</span><span>Free</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
        <li class="res-list-item">
          <div class="res-list-num mono">03</div>
          <div class="res-list-body">
            <div class="res-list-title">The Bedouin Navigation Model</div>
            <div class="res-list-desc">How the Bedouin way of thinking — stars, memory, landscape — applies to systems thinking in a world without a map.</div>
            <div class="res-list-meta mono"><span>Mental Model</span><span>Essay · Coming soon</span></div>
          </div>
          <div class="res-list-arrow">→</div>
        </li>
      </ul>
    </div>

  </div>
</div>

<!-- ─── NEWSLETTER ─────────────────────────────────────── -->
<div class="newsletter-band" id="newsletter">
  <div class="wrap">
    <div class="nl-label mono">
      <div class="nl-dot"></div>
      Published weekly
    </div>
    <h2 class="nl-title">
      The <em>Sand &amp; Silicon</em> Byte
    </h2>
    <p class="nl-desc">
      A weekly letter at the intersection of AI, the Gulf, and education.
      One big idea. Three signals. An ancient thread. A prompt you can use this week.
      Written from inside the systems — not from a think tank.
    </p>
    <!--
      BEEHIIV EMBED — Replace this form with your Beehiiv embed:
      Dashboard → Grow → Forms → Embed → copy iframe src
    -->
    <div class="nl-form">
      <input type="email" class="nl-input mono" placeholder="your@email.com" aria-label="Email address" />
      <a href="https://thesandandsiliconbyte.beehiiv.com" target="_blank" rel="noopener" class="nl-btn mono">Subscribe →</a>
    </div>
    <p class="nl-note mono">Free. One email a week. No sponsored content. Unsubscribe anytime.</p>
  </div>
</div>

<!-- ─── BASEERA / WRITING ──────────────────────────────── -->
<div class="section" id="writing">
  <div class="wrap">

    <div class="section-label">Baseera · بصيرة · Distilled reading</div>

    {latestEditions.length === 0 ? (
      <p class="empty-state">No editions yet — check back soon.</p>
    ) : (
      <ul class="writing-list">
        {latestEditions.map((edition) => (
          <li class="writing-item">
            <a href={`/baseera/${edition.slug}`} class="writing-link">
              <div class="writing-edition mono">
                Edition {String(edition.data.edition).padStart(3, '0')} · {edition.data.tags?.slice(0,2).join(' · ')}
              </div>
              <div class="writing-title">{edition.data.title}</div>
              <div class="writing-excerpt">{edition.data.finding}</div>
            </a>
            <div class="writing-arrow">→</div>
          </li>
        ))}
      </ul>
    )}

    <div style="margin-top: 32px;">
      <a href="/baseera" class="btn-text">All Baseera editions →</a>
    </div>

  </div>
</div>

</BaseLayout>

<style>
  /* ─── HERO ───────────────────────────────────────── */
  .hero {
    padding: 72px 0 64px;
    border-bottom: 1px solid var(--rule);
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-eyebrow::after {
    content: '';
    display: block;
    flex: 1;
    height: 1px;
    background: var(--sand-rule);
    max-width: 48px;
  }

  .hero-name {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .hero-identity {
    font-size: clamp(18px, 2vw, 22px);
    color: var(--ink-soft);
    font-style: italic;
    margin-bottom: 28px;
  }

  .hero-tagline {
    font-size: clamp(17px, 1.8vw, 20px);
    color: var(--ink-mid);
    line-height: 1.65;
    margin-bottom: 20px;
    max-width: 560px;
  }

  .hero-creds {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    margin-bottom: 36px;
  }

  .hero-creds span { white-space: nowrap; }
  .hero-creds .sep { margin: 0 10px; opacity: 0.4; }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ─── ABOUT STRIP ────────────────────────────────── */
  .about-strip {
    padding: 56px 0;
    border-bottom: 1px solid var(--rule);
    background: var(--page-warm);
  }

  .about-strip-inner {
    display: grid;
    grid-template-columns: 1fr 2.2fr;
    gap: 56px;
    align-items: start;
  }

  .about-strip-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 4px;
    letter-spacing: 0.04em;
  }

  .about-strip-handle {
    font-size: 11px;
    color: var(--sand-dark);
    margin-bottom: 20px;
  }

  .about-strip-img {
    width: 100%;
    aspect-ratio: 1;
    background: var(--sand-pale);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    border: 1px solid var(--rule);
  }

  .about-strip-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: 4px;
    overflow: hidden;
  }

  .about-strip-body {
    font-size: 17px;
    color: var(--ink-mid);
    line-height: 1.8;
  }

  .about-strip-body p { margin-bottom: 16px; }
  .about-strip-body p:last-of-type { margin-bottom: 0; }

  .about-quote {
    margin-top: 28px;
    padding: 16px 20px;
    border-left: 2px solid var(--sand);
    background: var(--sand-pale);
    font-style: italic;
    font-size: 17px;
    color: var(--ink-mid);
    line-height: 1.6;
    border-radius: 0 4px 4px 0;
  }

  .about-long { margin: 20px 0; }

  .about-long-toggle {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sand-dark);
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid var(--sand-rule);
    padding-bottom: 2px;
  }
  .about-long-toggle::-webkit-details-marker { display: none; }

  .about-long-body {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
  }
  .about-long-body p { margin-bottom: 14px; }
  .about-pillars {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  .about-socials {
    margin-top: 24px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .about-socials a {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
    transition: all 0.15s;
  }
  .about-socials a:hover { color: var(--sand-dark); border-color: var(--sand-rule); }

  /* ─── RESOURCES ──────────────────────────────────── */
  .resources-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 40px;
  }

  .res-tab {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 12px 20px;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: all 0.15s;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .res-tab:hover { color: var(--ink-mid); }

  .res-tab.active {
    color: var(--ink);
    border-bottom-color: var(--sand);
  }

  .res-panel { display: none; }
  .res-panel.active { display: block; }

  .res-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
  }

  .res-card {
    background: var(--page);
    padding: 28px;
    transition: background 0.15s;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .res-card:hover { background: var(--sand-pale); }

  .res-card-badge {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sand-dark);
    background: var(--sand-pale);
    border: 1px solid var(--sand-rule);
    padding: 2px 7px;
    border-radius: 2px;
    display: inline-block;
    width: fit-content;
  }

  .res-card-badge.free {
    color: var(--teal);
    background: rgba(13,115,119,0.06);
    border-color: rgba(13,115,119,0.2);
  }

  .res-card-title {
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
  }

  .res-card-desc {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.65;
    flex: 1;
  }

  .res-card-region {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.05em;
    margin-top: 4px;
  }

  .res-card-link {
    font-size: 10px;
    color: var(--sand-dark);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .res-note {
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
  }

  .res-note a {
    color: var(--sand-dark);
    border-bottom: 1px solid var(--sand-rule);
  }

  .res-list { list-style: none; }

  .res-list-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 22px 0;
    border-bottom: 1px solid var(--rule);
    cursor: pointer;
    transition: all 0.12s;
  }

  .res-list-item:last-child { border-bottom: none; }
  .res-list-item:hover .res-list-title { color: var(--sand-dark); }

  .res-list-num {
    font-size: 11px;
    color: var(--ink-faint);
    min-width: 28px;
    padding-top: 3px;
  }

  .res-list-body { flex: 1; }

  .res-list-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 4px;
    transition: color 0.15s;
  }

  .res-list-desc {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .res-list-meta {
    margin-top: 8px;
    font-size: 10px;
    color: var(--ink-faint);
    display: flex;
    gap: 12px;
  }

  .res-list-arrow {
    font-size: 16px;
    color: var(--rule);
    padding-top: 2px;
    transition: color 0.15s, transform 0.15s;
  }
