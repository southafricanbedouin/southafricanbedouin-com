---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const editions = await getCollection('baseera');
  return editions.map((edition) => ({
    params: { slug: edition.slug },
    props: { edition },
  }));
}

const { edition } = Astro.props;
const { Content } = await edition.render();
const { title, edition: num, date, article, articleUrl, author, finding, pattern, signal, tags, linkedinUrl } = edition.data;
---

<BaseLayout
  title={`Baseera Edition ${String(num).padStart(3,'0')}: ${title}`}
  description={finding}
>

<!-- Edition Header -->
<div class="edition-header">
  <div class="wrap">
    <div class="breadcrumb mono">
      <a href="/baseera">Baseera بصيرة</a>
      <span class="sep"> / </span>
      <span>Edition {String(num).padStart(3,'0')}</span>
    </div>

    <div class="edition-eyebrow mono">
      Edition {String(num).padStart(3,'0')}
      {tags && <span> · {tags.slice(0,3).join(' · ')}</span>}
    </div>
    <h1 class="edition-title">{title}</h1>
    <p class="edition-date mono">{date}</p>

    {article && (
      <div class="source-line mono">
        Source:
        {articleUrl ? (
          <a href={articleUrl} target="_blank" rel="noopener" class="source-link"> {article} ↗</a>
        ) : (
          <span class="source-italic"> {article}</span>
        )}
        {author && <span class="source-author"> — {author}</span>}
      </div>
    )}
  </div>
</div>

<!-- Three Layers -->
<div class="layers-section">
  <div class="wrap">

    <div class="layer">
      <div class="layer-label mono">01 · The Finding</div>
      <p class="layer-body">{finding}</p>
    </div>

    <div class="layer">
      <div class="layer-label mono">02 · The Pattern</div>
      <p class="layer-body">{pattern}</p>
    </div>

    <div class="layer layer--signal">
      <div class="layer-label mono">03 · The Signal</div>
      <p class="layer-body signal-body">{signal}</p>
    </div>

  </div>
</div>

<!-- Full Content -->
<div class="content-section">
  <div class="wrap">
    <div class="prose">
      <Content />
    </div>
  </div>
</div>

<!-- Footer Actions -->
<div class="edition-footer">
  <div class="wrap">
    <div class="footer-actions">
      {linkedinUrl && (
        <a href={linkedinUrl} target="_blank" rel="noopener" class="btn-dark">View on LinkedIn →</a>
      )}
      <a href="/baseera" class="btn-text">← All editions</a>
    </div>
  </div>
</div>

</BaseLayout>

<style>
  /* Header */
  .edition-header {
    padding: 64px 0 40px;
    border-bottom: 1px solid var(--rule);
  }

  .breadcrumb {
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    margin-bottom: 28px;
  }

  .breadcrumb a { color: var(--sand); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--sand-dark); }
  .breadcrumb .sep { color: var(--rule); }

  .edition-eyebrow {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 14px;
  }

  .edition-title {
    font-size: clamp(28px, 4.5vw, 48px);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .edition-date {
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    margin-bottom: 20px;
  }

  .source-line {
    font-size: 12px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    align-items: baseline;
  }

  .source-link {
    font-style: italic;
    color: var(--sand-dark);
    transition: opacity 0.15s;
  }
  .source-link:hover { opacity: 0.7; }

  .source-italic { font-style: italic; color: var(--ink-mid); }
  .source-author { color: var(--ink-soft); }

  /* Three Layers */
  .layers-section {
    padding: 56px 0;
    border-bottom: 1px solid var(--rule);
    background: var(--page-warm);
  }

  .layer {
    padding: 28px 0;
    border-bottom: 1px solid var(--rule);
  }

  .layer:last-child { border-bottom: none; padding-bottom: 0; }
  .layer:first-child { padding-top: 0; }

  .layer-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 14px;
  }

  .layer-body {
    font-size: 18px;
    color: var(--ink-mid);
    line-height: 1.75;
    max-width: 640px;
  }

  .layer--signal {
    background: var(--ink);
    padding: 32px;
    border-radius: 4px;
    margin-top: 8px;
    border-bottom: none;
  }

  .layer--signal .layer-label { color: var(--sand); }
  .signal-body { color: rgba(250,250,248,0.85); }

  /* Prose */
  .content-section {
    padding: 56px 0;
    border-bottom: 1px solid var(--rule);
  }

  .prose {
    font-size: 18px;
    color: var(--ink-mid);
    line-height: 1.8;
  }

  .prose :global(p) { margin-bottom: 1.3em; }

  .prose :global(h2),
  .prose :global(h3) {
    font-size: 1.2em;
    font-weight: 500;
    color: var(--ink);
    margin: 1.8em 0 0.6em;
    letter-spacing: -0.01em;
  }

  .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .prose :global(em) { font-style: italic; }

  .prose :global(blockquote) {
    padding: 14px 20px;
    border-left: 2px solid var(--sand);
    background: var(--sand-pale);
    font-style: italic;
    color: var(--ink-mid);
    border-radius: 0 4px 4px 0;
    margin: 1.5em 0;
  }

  /* Footer */
  .edition-footer {
    padding: 40px 0;
    background: var(--page-warm);
  }

  .footer-actions {
    display: flex;
    gap: 20px;
    align-items: center;
    flex-wrap: wrap;
  }

  @media (max-width: 760px) {
    .edition-header { padding: 40px 0 28px; }
    .layers-section { padding: 40px 0; }
  }
</style>
