---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const editions = await getCollection('baseera');
const sorted = editions.sort((a, b) => b.data.edition - a.data.edition);
---

<BaseLayout
  title="Baseera بصيرة"
  description="Bi-weekly distilled reading. One article. Three layers: The Finding, The Pattern, The Signal."
>

<div class="page-header">
  <div class="wrap">
    <div class="header-eyebrow mono">Archive</div>
    <h1 class="page-title">Baseera <span class="ar">بصيرة</span></h1>
    <p class="page-desc">
      One article or paper. Three layers: the finding, the pattern, the signal. Bi-weekly. No noise.
    </p>
  </div>
</div>

<div class="section">
  <div class="wrap">

    <div class="section-label">All editions</div>

    {sorted.length === 0 ? (
      <p class="empty-state">No editions yet — check back soon.</p>
    ) : (
      <ul class="editions-list">
        {sorted.map((edition) => {
          const dest = edition.data.linkedinUrl
            ? edition.data.linkedinUrl
            : `/baseera/${edition.slug}`;
          const isExternal = !!edition.data.linkedinUrl;
          return (
            <li class="edition-item">
              <a
                href={dest}
                class="edition-link"
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
              >
                <div class="edition-meta mono">
                  Edition {String(edition.data.edition).padStart(3, '0')}
                  {edition.data.tags && <span> · {edition.data.tags.slice(0,2).join(' · ')}</span>}
                  <span class="edition-date"> · {edition.data.date}</span>
                </div>
                <div class="edition-title">{edition.data.title}</div>
                <div class="edition-finding">{edition.data.finding}</div>
                {edition.data.article && (
                  <div class="edition-source mono">
                    {edition.data.article}
                    {edition.data.author && ` — ${edition.data.author}`}
                  </div>
                )}
                <div class="edition-cta mono">
                  {edition.data.linkedinUrl ? 'View carousel ↗' : 'Read edition →'}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}

  </div>
</div>

</BaseLayout>

<style>
  .page-header {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--rule);
  }

  .header-eyebrow {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 16px;
  }

  .page-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .ar {
    font-style: italic;
    color: var(--sand-dark);
  }

  .page-desc {
    font-size: 18px;
    color: var(--ink-soft);
    line-height: 1.65;
    max-width: 500px;
  }

  .editions-list { list-style: none; }

  .edition-item {
    padding: 36px 0;
    border-bottom: 1px solid var(--rule);
    transition: all 0.12s;
  }

  .edition-item:first-child { padding-top: 0; }
  .edition-item:last-child { border-bottom: none; }

  .edition-link { display: block; }

  .edition-meta {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 10px;
  }

  .edition-date { color: var(--ink-faint); }

  .edition-title {
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.25;
    margin-bottom: 12px;
    transition: color 0.15s;
    max-width: 640px;
  }

  .edition-item:hover .edition-title { color: var(--sand-dark); }

  .edition-finding {
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.65;
    margin-bottom: 14px;
    max-width: 620px;
  }

  .edition-source {
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    font-style: italic;
    margin-bottom: 16px;
  }

  .edition-cta {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sand);
    transition: color 0.15s, letter-spacing 0.15s;
  }

  .edition-item:hover .edition-cta {
    color: var(--sand-dark);
    letter-spacing: 0.14em;
  }

  .empty-state {
    font-size: 15px;
    color: var(--ink-faint);
    font-style: italic;
    padding: 40px 0;
  }

  @media (max-width: 760px) {
    .page-header { padding: 40px 0 32px; }
    .edition-item { padding: 28px 0; }
  }
</style>
