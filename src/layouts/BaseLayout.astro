---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Decoding the world, life & human systems — through a South African Bedouin lens.", ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

  <title>{title} — Muhammad Seedat</title>

  <style is:global>
    /* ─── TOKENS ─────────────────────────────────────── */
    :root {
      --sand:       #C8A96E;
      --sand-dark:  #8B6F3E;
      --sand-pale:  #F7F0E6;
      --sand-rule:  rgba(200,169,110,0.25);
      --ink:        #111111;
      --ink-mid:    #333333;
      --ink-soft:   #666666;
      --ink-faint:  #999999;
      --page:       #FFFFFF;
      --page-warm:  #FAFAF7;
      --rule:       #E8E4DE;
      --teal:       #0D7377;
    }

    /* ─── RESET ──────────────────────────────────────── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'EB Garamond', Georgia, serif;
      background: var(--page);
      color: var(--ink);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      font-size: 18px;
    }

    a { color: var(--ink); text-decoration: none; }
    a:hover { color: var(--sand-dark); }

    .mono { font-family: 'DM Mono', 'Courier New', monospace; }

    /* ─── LAYOUT ─────────────────────────────────────── */
    .wrap {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .wrap-wide {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ─── SECTION SHARED ─────────────────────────────── */
    .section { padding: 72px 0; }
    .section + .section { border-top: 1px solid var(--rule); }

    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sand);
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--sand-rule);
    }

    /* ─── BUTTONS ─────────────────────────────────────── */
    .btn-dark {
      display: inline-block;
      background: var(--ink);
      color: var(--page);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 12px 24px;
      border-radius: 3px;
      transition: background 0.15s;
    }
    .btn-dark:hover { background: var(--sand-dark); color: var(--page); }

    .btn-text {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-soft);
      border-bottom: 1px solid var(--rule);
      padding-bottom: 1px;
      transition: all 0.15s;
    }
    .btn-text:hover { color: var(--sand-dark); border-color: var(--sand-rule); }
  </style>
</head>
<body>

<!-- ─── NAV ─────────────────────────────────────────── -->
<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">southafricanbedouin<span class="dot">.</span>com <span class="nav-logo-sep">|</span> Muhammad Seedat</a>

    <div class="nav-right">
      <ul class="nav-links">
        <li>
          <button class="nav-drop-toggle" aria-haspopup="true">
            Resources <span class="chevron">▾</span>
          </button>
          <div class="nav-dropdown">
            <a href="/resources#tools"><span class="icon">🛠</span> Tools</a>
            <a href="/resources#guides"><span class="icon">📖</span> Guides</a>
            <a href="/resources#prompts"><span class="icon">✦</span> Prompts</a>
            <a href="/resources#models"><span class="icon">⬡</span> Models</a>
          </div>
        </li>
        <li><a href="/#newsletter">Newsletter</a></li>
        <li><a href="/baseera">Baseera</a></li>
        <li><a href="/#about">About</a></li>
      </ul>

      <a href="https://thesandandsiliconbyte.beehiiv.com" target="_blank" rel="noopener" class="nav-subscribe">Subscribe free</a>
    </div>
  </div>
</nav>

<main>
  <slot />
</main>

<!-- ─── FOOTER ──────────────────────────────────────── -->
<footer class="site-footer">
  <div class="wrap-wide">
    <div class="footer-inner">
      <div class="footer-brand mono">
        Muhammad Seedat · southafricanbedouin.com · Doha, Qatar
      </div>
      <ul class="footer-links">
        <li>
          <a href="https://linkedin.com/in/southafricanbedouin" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg class="footer-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </li>
        <li>
          <a href="https://southafricanbedouin.substack.com" target="_blank" rel="noopener" aria-label="Substack">
            <svg class="footer-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
          </a>
        </li>
        <li>
          <a href="https://thesandandsiliconbyte.beehiiv.com" target="_blank" rel="noopener" aria-label="Newsletter">
            <svg class="footer-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </a>
        </li>
        <li>
          <a href="/baseera" aria-label="Baseera">
            <svg class="footer-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>
          </a>
        </li>
        <li>
          <a href="https://instagram.com/southafricanbedouin" target="_blank" rel="noopener" aria-label="Instagram">
            <svg class="footer-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
        </li>
        <li>
          <a href="https://x.com/southafricanbedouin" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg class="footer-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </li>
      </ul>
      <p class="footer-copy">© {new Date().getFullYear()} Muhammad Seedat · All rights reserved</p>
    </div>
  </div>
</footer>

</body>
</html>

<style>
  /* ─── NAV ────────────────────────────────────────── */
  .site-nav {
    border-bottom: 1px solid var(--rule);
    background: var(--page);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .nav-logo {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--ink);
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-logo .dot { color: var(--sand); }
  .nav-logo-sep { color: var(--ink-faint); margin: 0 2px; font-weight: 300; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    list-style: none;
  }

  .nav-links > li { position: relative; }

  .nav-links a,
  .nav-drop-toggle {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-drop-toggle:hover { color: var(--sand-dark); }

  .nav-drop-toggle .chevron {
    font-size: 9px;
    opacity: 0.5;
    transition: transform 0.2s;
  }

  .nav-links li:hover .chevron { transform: rotate(180deg); }

  /* Dropdown */
  .nav-dropdown {
    position: absolute;
    top: calc(100% + 16px);
    left: -16px;
    background: var(--page);
    border: 1px solid var(--rule);
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    min-width: 160px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: all 0.18s ease;
    padding: 6px 0;
  }

  .nav-links li:hover .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-mid);
    text-transform: none;
    transition: background 0.1s;
  }

  .nav-dropdown a:hover {
    background: var(--sand-pale);
    color: var(--sand-dark);
  }

  .nav-dropdown a .icon { font-size: 14px; width: 18px; }

  .nav-subscribe {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--page);
    background: var(--ink);
    padding: 8px 18px;
    border-radius: 3px;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .nav-subscribe:hover { background: var(--sand-dark); color: var(--page); }

  /* ─── FOOTER ─────────────────────────────────────── */
  .site-footer {
    border-top: 1px solid var(--rule);
    padding: 40px 0;
    background: var(--page-warm);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-brand {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--ink-soft);
  }

  .footer-links {
    display: flex;
    gap: 24px;
    list-style: none;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    color: var(--ink-faint);
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--sand-dark); }

  .footer-icon {
    width: 17px;
    height: 17px;
    display: block;
  }

  .footer-copy {
    width: 100%;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--ink-faint);
    opacity: 0.5;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
    margin-top: 8px;
    letter-spacing: 0.04em;
  }

  @media (max-width: 760px) {
    .nav-links, .nav-subscribe { display: none; }
    .nav-logo { font-size: 12px; }
    .footer-links { display: none; }
  }
</style>
