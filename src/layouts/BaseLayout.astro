---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Decoding the world, life & human systems — through a South African Bedouin lens.", ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

  <title>{title} — Muhammad Seedat</title>

  <style is:global>
    /* ─── TOKENS ─────────────────────────────────────── */
    :root {
      --sand:       #C8A96E;
      --sand-dark:  #8B6F3E;
      --sand-pale:  #F7F0E6;
      --sand-rule:  rgba(200,169,110,0.25);
      --ink:        #111111;
      --ink-mid:    #333333;
      --ink-soft:   #666666;
      --ink-faint:  #999999;
      --page:       #FFFFFF;
      --page-warm:  #FAFAF7;
      --rule:       #E8E4DE;
      --teal:       #0D7377;
    }

    /* ─── RESET ──────────────────────────────────────── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'EB Garamond', Georgia, serif;
      background: var(--page);
      color: var(--ink);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      font-size: 18px;
    }

    a { color: var(--ink); text-decoration: none; }
    a:hover { color: var(--sand-dark); }

    .mono { font-family: 'DM Mono', 'Courier New', monospace; }

    /* ─── LAYOUT ─────────────────────────────────────── */
    .wrap {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .wrap-wide {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ─── SECTION SHARED ─────────────────────────────── */
    .section { padding: 72px 0; }
    .section + .section { border-top: 1px solid var(--rule); }

    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sand);
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--sand-rule);
    }

    /* ─── BUTTONS ─────────────────────────────────────── */
    .btn-dark {
      display: inline-block;
      background: var(--ink);
      color: var(--page);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 12px 24px;
      border-radius: 3px;
      transition: background 0.15s;
    }
    .btn-dark:hover { background: var(--sand-dark); color: var(--page); }

    .btn-text {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-soft);
      border-bottom: 1px solid var(--rule);
      padding-bottom: 1px;
      transition: all 0.15s;
    }
    .btn-text:hover { color: var(--sand-dark); border-color: var(--sand-rule); }
  </style>
</head>
<body>

<!-- ─── NAV ─────────────────────────────────────────── -->
<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">mseedat<span class="dot">.</span>co</a>

    <div class="nav-right">
      <ul class="nav-links">
        <li>
          <button class="nav-drop-toggle" aria-haspopup="true">
            Resources <span class="chevron">▾</span>
          </button>
          <div class="nav-dropdown">
            <a href="/resources#tools"><span class="icon">🛠</span> Tools</a>
            <a href="/resources#guides"><span class="icon">📖</span> Guides</a>
            <a href="/resources#prompts"><span class="icon">✦</span> Prompts</a>
            <a href="/resources#models"><span class="icon">⬡</span> Models</a>
          </div>
        </li>
        <li><a href="/#newsletter">Newsletter</a></li>
        <li><a href="/baseera">Baseera</a></li>
        <li><a href="/#about">About</a></li>
      </ul>

      <a href="https://thesandandsiliconbyte.beehiiv.com" target="_blank" rel="noopener" class="nav-subscribe">Subscribe free</a>
    </div>
  </div>
</nav>

<main>
  <slot />
</main>

<!-- ─── FOOTER ──────────────────────────────────────── -->
<footer class="site-footer">
  <div class="wrap-wide">
    <div class="footer-inner">
      <div class="footer-brand mono">
        Muhammad Seedat · mseedat.co · 1four1 Media · Doha, Qatar
      </div>
      <ul class="footer-links">
        <li><a href="https://linkedin.com/in/southafricanbedouin" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="https://southafricanbedouin.substack.com" target="_blank" rel="noopener">Substack</a></li>
        <li><a href="https://thesandandsiliconbyte.beehiiv.com" target="_blank" rel="noopener">Newsletter</a></li>
        <li><a href="/baseera">Baseera</a></li>
      </ul>
      <p class="footer-copy">© {new Date().getFullYear()} Muhammad Seedat · All rights reserved</p>
    </div>
  </div>
</footer>

</body>
</html>

<style>
  /* ─── NAV ────────────────────────────────────────── */
  .site-nav {
    border-bottom: 1px solid var(--rule);
    background: var(--page);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .nav-logo {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--ink);
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-logo .dot { color: var(--sand); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    list-style: none;
  }

  .nav-links > li { position: relative; }

  .nav-links a,
  .nav-drop-toggle {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-drop-toggle:hover { color: var(--sand-dark); }

  .nav-drop-toggle .chevron {
    font-size: 9px;
    opacity: 0.5;
    transition: transform 0.2s;
  }

  .nav-links li:hover .chevron { transform: rotate(180deg); }

  /* Dropdown */
  .nav-dropdown {
    position: absolute;
    top: calc(100% + 16px);
    left: -16px;
    background: var(--page);
    border: 1px solid var(--rule);
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    min-width: 160px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: all 0.18s ease;
    padding: 6px 0;
  }

  .nav-links li:hover .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--ink-mid);
    text-transform: none;
    transition: background 0.1s;
  }

  .nav-dropdown a:hover {
    background: var(--sand-pale);
    color: var(--sand-dark);
  }

  .nav-dropdown a .icon { font-size: 14px; width: 18px; }

  .nav-subscribe {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--page);
    background: var(--ink);
    padding: 8px 18px;
    border-radius: 3px;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .nav-subscribe:hover { background: var(--sand-dark); color: var(--page); }

  /* ─── FOOTER ─────────────────────────────────────── */
  .site-footer {
    border-top: 1px solid var(--rule);
    padding: 40px 0;
    background: var(--page-warm);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-brand {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--ink-soft);
  }

  .footer-links {
    display: flex;
    gap: 24px;
    list-style: none;
  }

  .footer-links a {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--sand-dark); }

  .footer-copy {
    width: 100%;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--ink-faint);
    opacity: 0.5;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
    margin-top: 8px;
    letter-spacing: 0.04em;
  }

  @media (max-width: 760px) {
    .nav-links, .nav-subscribe { display: none; }
    .nav-logo { font-size: 12px; }
    .footer-links { display: none; }
  }
</style>
